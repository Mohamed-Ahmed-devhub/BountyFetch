// schema.prisma — BountyFetch v3 — Production Ready
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String   @id
  name            String
  email           String   @unique
  password        String   @default("")
  avatar          String?
  skills          String[]
  bio             String?  @db.Text
  jobTitle        String?
  linkedinUrl     String?
  githubUrl       String?
  yearsExperience Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  savedTasks SavedTask[]
  proposals  Proposal[]
  tickets    Ticket[]

  @@index([email])
  @@map("users")
}

model Task {
  id          String   @id @default(cuid())
  externalId  String   @unique
  title       String
  description String   @db.Text
  skills      String[]
  budget      String?
  source      String
  url         String?
  domain      String   @default("web")
  postedAt    DateTime @default(now())
  createdAt   DateTime @default(now())

  savedBy   SavedTask[]
  proposals Proposal[]

  @@index([source])
  @@index([domain])
  @@index([postedAt])
  @@map("tasks")
}

model SavedTask {
  userId  String
  taskId  String
  savedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@id([userId, taskId])
  @@index([userId])
  @@index([taskId])
  @@map("saved_tasks")
}

model Proposal {
  id        String   @id @default(cuid())
  userId    String
  taskId    String
  language  String
  content   String   @db.Text
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([taskId])
  @@map("proposals")
}

model ChatMessage {
  id        String   @id @default(cuid())
  room      String
  userId    String
  userName  String
  userAvatar String?
  content   String   @db.Text
  createdAt DateTime @default(now())

  @@index([room])
  @@index([userId])
  @@index([createdAt])
  @@map("chat_messages")
}

model Ticket {
  id          String   @id @default(cuid())
  userId      String
  type        String
  title       String
  description String   @db.Text
  screenshot  String?
  status      String   @default("open")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("tickets")
}
