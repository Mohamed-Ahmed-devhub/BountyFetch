// schema.prisma — aligned to actual Supabase database structure

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

// ── User profile — maps to the "profiles" table in Supabase ──────────────────
model User {
  id             String   @id  @db.Uuid
  name           String?
  email          String?
  avatarUrl      String?  @map("avatar_url")
  bio            String?  @db.Text
  role           String?  @default("freelancer")
  specialty      String?
  skills         String[]
  jobTitle       String?  @map("job_title")
  linkedinUrl    String?  @map("linkedin_url")
  githubUrl      String?  @map("github_url")
  yearsExperience Int?    @map("years_experience")
  onboarded      Boolean  @default(false)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt      @map("updated_at")

  proposals  Proposal[]
  tickets    Ticket[]

  @@map("profiles")
}

// ── Task — scraped from external sources ─────────────────────────────────────
model Task {
  id          String   @id @default(cuid())
  externalId  String   @unique @map("external_id")
  title       String
  description String   @db.Text
  skills      String[]
  budget      String?
  source      String
  url         String?
  domain      String   @default("web")
  postedAt    DateTime @default(now()) @map("posted_at")
  createdAt   DateTime @default(now()) @map("created_at")

  proposals Proposal[]

  @@index([source])
  @@index([domain])
  @@index([postedAt])
  @@map("tasks")
}

// ── Saved tasks — uses Supabase saved_tasks table ────────────────────────────
// Note: DB has UUID PK + unique(user_id, task_id) — no composite PK
model SavedTask {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  taskId    String   @map("task_id")
  taskTitle String?  @map("task_title")
  source    String?
  budget    String?
  status    String   @default("active")
  savedAt   DateTime @default(now()) @map("saved_at")

  @@unique([userId, taskId])
  @@index([userId])
  @@map("saved_tasks")
}

// ── Proposals — AI-generated ──────────────────────────────────────────────────
model Proposal {
  id        String   @id @default(cuid())
  userId    String   @map("user_id") @db.Uuid
  taskId    String   @map("task_id")
  language  String
  content   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([userId, taskId])
  @@index([userId])
  @@index([taskId])
  @@map("proposals")
}

// ── Chat messages ─────────────────────────────────────────────────────────────
model ChatMessage {
  id         String   @id @default(uuid()) @db.Uuid
  room       String
  userId     String   @map("user_id")
  userName   String   @map("user_name")
  userAvatar String?  @map("user_avatar")
  content    String   @db.Text
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([room])
  @@index([userId])
  @@map("chat_messages")
}

// ── Support tickets ───────────────────────────────────────────────────────────
model Ticket {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  type        String?
  title       String
  description String   @db.Text
  screenshot  String?  @map("screenshot_url")
  status      String   @default("open")
  adminReply  String?  @map("admin_reply")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt      @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("support_tickets")
}
