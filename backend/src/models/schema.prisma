// ===================================================
// schema.prisma - تصميم قاعدة البيانات
// ===================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// جدول المستخدمين
model User {
  id         String      @id @default(cuid())
  name       String
  email      String      @unique
  password   String
  skills     String[]    // مصفوفة المهارات
  createdAt  DateTime    @default(now())
  
  savedTasks SavedTask[]
}

// جدول المهام المصطادة
model Task {
  id          String      @id @default(cuid())
  externalId  String      @unique // الـ ID من المصدر الأصلي
  title       String
  description String      @db.Text
  skills      String[]
  budget      String?
  source      String      // telegram | reddit | twitter | rss
  url         String?
  postedAt    DateTime    @default(now())
  
  savedBy     SavedTask[]
}

// جدول المهام المحفوظة (علاقة Many-to-Many)
model SavedTask {
  userId  String
  taskId  String
  savedAt DateTime @default(now())
  
  user    User @relation(fields: [userId], references: [id])
  task    Task @relation(fields: [taskId], references: [id])
  
  @@id([userId, taskId]) // مفتاح مركب - منع الحفظ المكرر
}
