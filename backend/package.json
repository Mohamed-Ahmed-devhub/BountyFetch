{
  "name": "bountyfetch-backend",
  "version": "3.0.0",
  "main": "src/app.js",
  "scripts": {
    "dev": "nodemon src/app.js",
    "start": "node src/app.js",
    "db:gen": "prisma generate --schema=src/models/schema.prisma",
    "db:push": "prisma db push --schema=src/models/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=src/models/schema.prisma",
    "postinstall": "prisma generate --schema=src/models/schema.prisma"
  },
  "dependencies": {
    "@google/generative-ai": "^0.14.0",
    "@prisma/client": "^5.10.2",
    "@socket.io/redis-adapter": "^8.3.0",
    "@supabase/supabase-js": "^2.43.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "rss-parser": "^3.13.0",
    "socket.io": "^4.7.4",
    "telegraf": "^4.16.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.0",
    "prisma": "^5.10.2"
  },
  "prisma": {
    "schema": "src/models/schema.prisma"
  }
}
