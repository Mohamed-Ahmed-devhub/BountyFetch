# ===================================================
# .gitignore — ملفات يجب ألا تُرفع على GitHub
# ===================================================

# Dependencies
node_modules/
.pnp
.pnp.js

# Build output
dist/
build/
.next/

# Environment variables — مهم جداً!
.env
.env.local
.env.production
.env.*.local

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editor
.vscode/settings.json
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Prisma
*.db
*.db-journal

# Cache
.cache/
.parcel-cache/
